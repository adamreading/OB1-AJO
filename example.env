# Open Brain (AJO): Environment Template
# Copy this file to .env and fill in real values. .env is gitignored.
#
# Variables are grouped by what they control. Anything marked REQUIRED must
# be set or the corresponding service won't start. OPTIONAL has a sensible
# default in code; only set if you want to override.

# ──────────────────────────────────────────────────────────────────────────
# Core infrastructure (REQUIRED for everything)
# ──────────────────────────────────────────────────────────────────────────

# Supabase project endpoint and service-role secret.
# Found in your Supabase project: Settings → API.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="sb_secret_your_service_role_key"

# Access key the MCP server (open-brain-mcp) checks on every request, AND
# the dashboard uses to authenticate against the REST gateway. Set the same
# value as a Supabase Edge Function secret:
#   npx supabase secrets set MCP_ACCESS_KEY=sk-...
# Add it to .env locally too so smoke-gate + scripts can hit the API.
MCP_ACCESS_KEY="sk-your-access-key"

# Anon/publishable key — only needed for the smoke test's end-to-end RLS
# probe. Without it that one check is skipped with a clear message.
# SUPABASE_ANON_KEY="sb_publishable_your_anon_key"

# ──────────────────────────────────────────────────────────────────────────
# Local LLM (Ollama) — REQUIRED for the brain worker + wiki compiler
# ──────────────────────────────────────────────────────────────────────────

# Ollama HTTP API base. Default endpoint of a stock Ollama install.
OLLAMA_URL="http://localhost:11434/api"

# Model used by the worker (entity extraction) AND the wiki compiler
# (article generation). Both call this single model. gemma4:26b stays
# warm in VRAM if you also use it for other AI jobs; qwen3:30b is the
# AJO default for higher-quality extraction at slightly more cost.
OLLAMA_MODEL="gemma4:26b"

# Optional worker-only fallback chain. When the primary OLLAMA_MODEL
# produces unparseable JSON OR a runaway token-repetition loop (gemma4's
# "/task_details/task_details/…" failure), the worker tries each model in
# this list before giving up on the thought. Empty = no fallback.
# Recommended for gemma4 users: qwen3:30b doesn't share gemma's loop
# failure mode, so it catches almost all gemma failures.
WORKER_MODEL_CHAIN="qwen3:30b"

# Min number of consecutive repetitions of any 4-30 char substring in raw
# model output that flags a token loop. 8 has zero false positives on
# real captures and catches gemma loops well before the 100+ repeat range.
WORKER_LOOP_REPEAT_THRESHOLD=8

# Parallel Ollama extractions per poll tick. Default 1 (serial). Bump to
# keep the GPU busy when the queue has multiple pending thoughts. Pair
# with the OS-level OLLAMA_NUM_PARALLEL env var on the Ollama service
# itself (Windows: System Properties → Environment Variables, restart
# Ollama; or PowerShell `[Environment]::SetEnvironmentVariable(...)`).
# WORKER_CONCURRENCY must be <= OLLAMA_NUM_PARALLEL; otherwise requests
# queue inside Ollama and you get no speedup. Recommended for a 5090:
# OLLAMA_NUM_PARALLEL=4 + WORKER_CONCURRENCY=2 (start conservative).
WORKER_CONCURRENCY=1

# Cascade entity extraction — Cognee-inspired 2-round prompt that targets the
# failure mode where the model stops at 5-8 entities on a long Plaud transcript.
# Round 2 only fires when content length > WORKER_CASCADE_MIN_CHARS AND round 1
# returned < WORKER_CASCADE_TRIGGER_ENTITIES, so short captures don't pay the
# extra latency. Round 2 is entity-recall only; round 1 keeps authority over
# type/context/summary. Set WORKER_CASCADE_ENABLED=false to disable.
WORKER_CASCADE_ENABLED=true
WORKER_CASCADE_MIN_CHARS=3000
WORKER_CASCADE_TRIGGER_ENTITIES=8

# Wiki-compiler temperature (recipes/entity-wiki/generate-wiki.mjs).
# 0.5 = enough stochasticity to break gemma4's prose-mode token loops
# (the ",er,er,er,er..." Adam Ososki failure) while keeping articles
# coherent. Bump higher for more creative wikis.
OLLAMA_TEMPERATURE=0.5

# Worker (entity-extraction) temperature. MUST stay at or very near 0.
# Tried 0.5 once -- gemma4 fell into intra-JSON-object token loops
# (emitting `"type": "tool"` 80 times mid-output) that the structural
# JSON repair pass cannot recover. Greedy decoding + Ollama's JSON
# grammar constraint is the reliable combination for structured output.
WORKER_TEMPERATURE=0

# Hard ceiling on a single Ollama request before AbortController kills it.
# Worker: real entity-extraction completes in 1-30s; past 90s the model is
# stuck in a token loop and we want to fail fast and move on.
# Wiki: articles are slower (5-60s typical); past 180s assume hang.
OLLAMA_TIMEOUT_MS=90000
WIKI_LLM_TIMEOUT_MS=180000

# Max tokens the model can generate per call. Worker JSON output is tiny
# (~200 tokens); 4096 is generous headroom that stops runaway generation
# even when the model refuses to emit a stop token.
OLLAMA_NUM_PREDICT=4096

# Input context window — Ollama's per-request num_ctx. The model's default
# is 2048 which SILENTLY TRUNCATES any prompt past 2k tokens. Worker rarely
# needs more than 8k for a single thought; 32k gives huge headroom. Wiki
# compiler can feed ~14k tokens of snippets + structure; 65k uses the
# runner's full KvSize. The Ollama runner allocates KV cache at load time
# (per server.log) so setting larger num_ctx here doesn't reallocate VRAM.
OLLAMA_NUM_CTX=32768
WIKI_NUM_CTX=65536

# ──────────────────────────────────────────────────────────────────────────
# Wiki compiler input caps (recipes/entity-wiki/generate-wiki.mjs)
# ──────────────────────────────────────────────────────────────────────────

# How many thoughts each wiki article gets to "see". For an entity with
# 100s of linked thoughts (a major person/project), bigger = more
# comprehensive prose at the cost of generation time. 60 linked + 30
# semantic = ~4x more signal than the original 25/15 defaults.
WIKI_MAX_LINKED=60
WIKI_MAX_SEMANTIC=30

# Per-snippet content truncation. Each thought's content is trimmed to
# this many chars before the LLM sees it. 500 covers most one-sentence
# Plaud insights without truncation; bump higher for transcripts.
WIKI_SNIPPET_CHARS=500

# Min entity-link count before a wiki page is generated. Filters out
# noise entities mentioned in a single thought.
# MIN_LINKED_FOR_WIKI=3

# ──────────────────────────────────────────────────────────────────────────
# Brain worker (scripts/local-brain-worker.js)
# ──────────────────────────────────────────────────────────────────────────

# Worker poll interval in ms. Lower = faster pickup of new captures,
# higher = less CPU/REST chatter. 10000 (10s) is the AJO default.
# LOCAL_WORKER_POLL_MS=10000

# Initial kanban status for newly-captured task/idea thoughts.
# KANBAN_INITIAL_STATUS=backlog

# ──────────────────────────────────────────────────────────────────────────
# Embeddings + LLM fallback (OpenRouter) — REQUIRED for capture + search
# ──────────────────────────────────────────────────────────────────────────

# OpenRouter key. Used by Edge Functions for embedding generation
# (text-embedding-3-small, 1536d) and by recipes (Perplexity import,
# synthesize-persona) for LLM calls. Set the same value as a Supabase
# secret so the Edge Function can use it server-side.
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"

# ──────────────────────────────────────────────────────────────────────────
# Classification context — drives the worker's work/personal call
# ──────────────────────────────────────────────────────────────────────────

# Short natural-language descriptions of what counts as "work" vs
# "personal". The LLM uses these to classify each new thought.
WORK_CONTEXT_DESC="YOUR COMPANY NAME projects and professional tasks"
PERSONAL_CONTEXT_DESC="YOUR SIDE PROJECTS and home life"

# Subject name — used by synthesize-persona.mjs and any other scripts
# that need to identify "the user" vs other people in the brain.
SUBJECT_NAME="Your Name"
